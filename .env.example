# Copy values into `.secrets.env`; do not commit filled secret files.

ASTRA_USERNAME=
ASTRA_PASSWORD=
ASTRA_API_URL=https://astra-cloud.com/readyxnet/source/login/csandroid.php
ASTRA_WEB_LOGIN_URL=https://astra-cloud.com/readyxnet/source/login/csloginw.php

# Optional manual web-session fallback for `tools/astra_web_probe.py`.
# Fill these from an already logged-in browser session when mobile APIs are down.
ASTRA_WEB_BASE_URL=https://astra-cloud.com/astra04/readyxnet/source/pm
ASTRA_WEB_SESSION_ID=
ASTRA_WEB_COOKIE=
ASTRA_WEB_GRAPH_TOTAL_ID=-24557

# Optional local anti-bot helper endpoints used only by `tools/astra_web_login_probe.py`.
FLARESOLVERR_URL=http://192.168.1.104:31027/v1
BYPARR_URL=http://192.168.1.104:30230/v1

# Optional defaults for raw API probing.
ASTRA_IMMO=-1
ASTRA_YEAR=2026
ASTRA_MONTH=-1
ASTRA_DATE=-1
ASTRA_MEDIUM=1
ASTRA_LANGUAGE=de

# Comma-separated Android API actions for `tools/astra_raw_dump.py`.
ASTRA_ACTIONS=get_mtr_lzs,get_mtr_eb,get_mtr_autarkie,get_mtr_vb_overview,get_mtr_verbrauch,get_mtr_vbmed,get_mtr_hist,get_verbrauch,get_wf,lngchg_medium_list
