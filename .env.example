# Copy values into `.secrets.env`; do not commit filled secret files.

ASTRA_USERNAME=
ASTRA_PASSWORD=
ASTRA_API_URL=https://astra-cloud.com/readyxnet/source/login/csandroid.php

# Optional defaults for raw API probing.
ASTRA_IMMO=-1
ASTRA_YEAR=2026
ASTRA_MONTH=-1
ASTRA_DATE=-1
ASTRA_MEDIUM=1
ASTRA_LANGUAGE=de

# Comma-separated Android API actions for `tools/astra_raw_dump.py`.
ASTRA_ACTIONS=get_mtr_lzs,get_mtr_eb,get_mtr_autarkie,get_mtr_vb_overview,get_mtr_verbrauch,get_mtr_vbmed,get_mtr_hist,get_verbrauch,get_wf,lngchg_medium_list
