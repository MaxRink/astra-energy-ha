.DS_Store
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/

# Local credentials. Keep `.env.example` tracked, but never commit filled files.
.env
.env.*
.secrets.env
.secrets.env.*
